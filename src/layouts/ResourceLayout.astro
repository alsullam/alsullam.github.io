---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    author: string;
    category: string;
    tags: string[];
    rating: number;
    link?: string;
  };
}

const { frontmatter: r } = Astro.props;
---

<Base title={r.title}>
  <div class="container--narrow">
    <div class="breadcrumb">
      <a href="/">home</a>
      <span>/</span>
      <a href="/resources">resources</a>
      <span>/</span>
      <span style="color: var(--green);">{r.title.toLowerCase().slice(0, 24)}&hellip;</span>
    </div>

    <div class="page-header">
      <div class="page-header__meta">
        <span class="tag tag--resource">resource</span>
        <span class="dot"></span>
        <span class="meta-author">{r.author}</span>
        <span class="dot"></span>
        <span class="meta-cat">{r.category}</span>
      </div>
      <h1>{r.title}</h1>
      <div class="rating">{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
      <div class="page-header__tags">
        {r.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </div>

    {r.link && (
      <div style="margin-bottom: 3rem;">
        <a href={r.link} class="related-link" target="_blank" rel="noopener">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:0.6;">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Visit Resource ↗
        </a>
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    <div class="back-link">
      <a href="/resources">← back to resources</a>
    </div>
  </div>
</Base>

<style>
.breadcrumb {
  padding: 2rem 0 0;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.5rem;
  align-items: center;
}
.breadcrumb a { color: var(--text-muted); }
.breadcrumb a:hover { color: var(--text); }
.meta-author, .meta-cat {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
}
.rating {
  font-size: 0.9rem;
  color: var(--accent);
  letter-spacing: 0.05em;
  margin-top: 0.75rem;
  opacity: 0.7;
}
.back-link {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.back-link a {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.1em;
}
.back-link a:hover { color: var(--text); }
</style>
