---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    desc: string;
    status: 'active' | 'wip' | 'paused';
    date: string;
    tags: string[];
    github?: string;
    concepts?: { title: string; slug: string }[];
    resources?: { title: string; slug: string }[];
    experiments?: { title: string; slug: string }[];
  };
}

const { frontmatter: p } = Astro.props;
---

<Base title={p.title}>
  <div class="container--narrow">
    <div class="breadcrumb">
      <a href="/">home</a>
      <span>/</span>
      <a href="/projects">projects</a>
      <span>/</span>
      <span style="color: var(--blue);">{p.title.toLowerCase()}</span>
    </div>

    <div class="page-header">
      <div class="page-header__meta">
        <span class="tag tag--project">project</span>
        <span class={`status status--${p.status}`}>
          <span class="status__dot"></span>
          {p.status}
        </span>
        <span class="dot"></span>
        <span class="meta-date">{p.date}</span>
      </div>
      <h1>{p.title}</h1>
      <p class="page-desc">{p.desc}</p>
      <div class="page-header__tags">
        {p.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </div>

    {p.github && (
      <div style="margin-bottom: 3rem;">
        <a href={p.github} class="related-link" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="opacity: 0.6;">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View Source Code
        </a>
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    {p.concepts && p.concepts.length > 0 && (
      <div class="related-section">
        <p class="section-label">Related Concepts</p>
        <div class="related-grid">
          {p.concepts.map(c => (
            <a href={`/concepts/${c.slug}`} class="related-link">
              <span class="tag tag--concept" style="margin: 0; padding: 0.15em 0.4em; font-size: 0.6rem;">concept</span>
              {c.title}
            </a>
          ))}
        </div>
      </div>
    )}

    {p.resources && p.resources.length > 0 && (
      <div class="related-section" style="margin-top: 2rem; padding-top: 0; border: none;">
        <p class="section-label">Related Resources</p>
        <div class="related-grid">
          {p.resources.map(r => (
            <a href={`/resources/${r.slug}`} class="related-link">
              <span class="tag tag--resource" style="margin: 0; padding: 0.15em 0.4em; font-size: 0.6rem;">resource</span>
              {r.title}
            </a>
          ))}
        </div>
      </div>
    )}

    {p.experiments && p.experiments.length > 0 && (
      <div class="related-section" style="margin-top: 2rem; padding-top: 0; border: none;">
        <p class="section-label">Related Experiments</p>
        <div class="related-grid">
          {p.experiments.map(e => (
            <a href={`/experiments/${e.slug}`} class="related-link">
              <span class="tag tag--experiment" style="margin: 0; padding: 0.15em 0.4em; font-size: 0.6rem;">exp</span>
              {e.title}
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="back-link">
      <a href="/projects">← back to projects</a>
    </div>
  </div>
</Base>

<style>
.breadcrumb {
  padding: 2rem 0 0;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.5rem;
  align-items: center;
}
.breadcrumb a { color: var(--text-muted); }
.breadcrumb a:hover { color: var(--text); }
.meta-date {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
}
.page-desc {
  margin-top: 1rem;
  font-size: 1rem;
  color: var(--text-dim);
  max-width: 55ch;
  line-height: 1.8;
}
.back-link {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.back-link a {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.1em;
}
.back-link a:hover { color: var(--text); }
</style>
