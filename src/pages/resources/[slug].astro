---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const r = entry.data;

type Heading = { depth: number; slug: string; text: string };
---

<Base title={r.title}>
  <div class="toc-layout">

    <!-- Main content -->
    <div class="toc-content">
      <div class="breadcrumb">
        <a href="/">home</a><span>/</span>
        <a href="/resources">resources</a><span>/</span>
        <span style="color: var(--green);">{entry.id}</span>
      </div>

      <div class="page-header">
        <div class="page-header__meta">
          <span class="tag tag--resource">resource</span>
          <span class="dot"></span>
          <span class="mono-dim">{r.author}</span>
          <span class="dot"></span>
          <span class="mono-dim">{r.category}</span>
        </div>
        <h1>{r.title}</h1>
        <div class="rating">{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
        <div class="page-header__tags">
          {r.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      </div>

      {r.link && (
        <div style="margin-bottom: 3rem;">
          <a href={r.link} class="related-link" target="_blank" rel="noopener">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:0.6;flex-shrink:0;">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            Visit Resource ↗
          </a>
        </div>
      )}

      <div class="prose">
        <Content />
      </div>

      <div class="back-link">
        <a href="/resources">← back to resources</a>
      </div>
    </div>

    <!-- Right ToC -->
    {headings.filter((h: Heading) => h.depth <= 3).length > 0 && (
      <aside class="page-toc">
        <p class="page-toc__label">On this page</p>
        <nav class="page-toc__nav">
          {headings
            .filter((h: Heading) => h.depth <= 3)
            .map((h: Heading) => (
              <a
                href={'#' + h.slug}
                class={'page-toc__link page-toc__link--h' + h.depth}
                data-heading={h.slug}
              >
                {h.text}
              </a>
            ))
          }
        </nav>
      </aside>
    )}

  </div>
</Base>

<style>
.breadcrumb {
  padding: 2rem 0 0;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.5rem;
  align-items: center;
}
.breadcrumb a { color: var(--text-muted); }
.breadcrumb a:hover { color: var(--text); }
.mono-dim { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted); }
.rating {
  font-size: 0.88rem;
  color: var(--accent);
  letter-spacing: 0.06em;
  margin-top: 0.75rem;
  opacity: 0.65;
}
.back-link {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.back-link a {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.08em;
}
.back-link a:hover { color: var(--text); }
</style>
