---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const all = await getCollection('projects');

  const byProject: Record<string, typeof all> = {};
  for (const entry of all) {
    const proj = entry.id.split('/')[0];
    if (!byProject[proj]) byProject[proj] = [];
    byProject[proj].push(entry);
  }

  const paths = [];
  for (const [projSlug, chapters] of Object.entries(byProject)) {
    const sorted = chapters.sort((a, b) => a.data.chapter - b.data.chapter);
    for (const chapter of sorted) {
      paths.push({
        params: { slug: projSlug, chapter: String(chapter.data.chapter) },
        props: { entry: chapter, allChapters: sorted, projSlug },
      });
    }
  }
  return paths;
}

const { entry, allChapters, projSlug } = Astro.props;
const { Content, headings } = await render(entry);
const p = entry.data;
const intro = allChapters.find(c => c.data.chapter === 0)!;
const ip = intro.data;

type Link = { title: string; slug: string };
type Heading = { depth: number; slug: string; text: string };
type ChEntry = typeof allChapters[number];
type ChangelogEntry = { version: string; date: string; notes: string };

const pageTitle = ip.title + ' — ' + p.title;
const introUrl = '/projects/' + projSlug + '/0';
const prevChapter = allChapters.find((c: ChEntry) => c.data.chapter === p.chapter - 1);
const nextChapter = allChapters.find((c: ChEntry) => c.data.chapter === p.chapter + 1);
---

<Base title={pageTitle}>
  <div class="proj-layout">

    <!-- LEFT SIDEBAR -->
    <aside class="proj-sidebar" id="proj-sidebar">
      <div class="proj-sidebar__header">
        <a href="/projects" class="proj-sidebar__back">← Projects</a>
        <div class="proj-sidebar__title">{ip.title}</div>
        <div class="proj-sidebar__meta">
          <span class={'status status--' + ip.status}>
            <span class="status__dot"></span>{ip.status}
          </span>
          {ip.version && <span class="proj-sidebar__version">{'v' + ip.version}</span>}
        </div>
      </div>

      <nav class="proj-sidebar__nav">
        {allChapters.map((ch: ChEntry) => {
          const chUrl = '/projects/' + projSlug + '/' + ch.data.chapter;
          const numLabel = ch.data.chapter === 0 ? '00' : String(ch.data.chapter).padStart(2, '0');
          const isActive = ch.data.chapter === p.chapter;
          return (
            <a href={chUrl} class={'proj-sidebar__link' + (isActive ? ' active' : '')}>
              <span class="proj-sidebar__link-num">{numLabel}</span>
              <span class="proj-sidebar__link-title">{ch.data.title}</span>
            </a>
          );
        })}
      </nav>

      {ip.github && (
        <a href={ip.github} class="proj-sidebar__github" target="_blank" rel="noopener">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      )}

      {ip.tags && (
        <div class="proj-sidebar__tags">
          {ip.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      )}

      {p.chapter === 0 && ip.changelog && ip.changelog.length > 0 && (
        <div class="proj-sidebar__changelog">
          <p class="section-label" style="margin-bottom: 0.75rem;">Changelog</p>
          {ip.changelog.map((cl: ChangelogEntry) => (
            <div class="changelog-entry">
              <span class="changelog-version">{'v' + cl.version}</span>
              <span class="changelog-date">{cl.date}</span>
              <p class="changelog-notes">{cl.notes}</p>
            </div>
          ))}
        </div>
      )}
    </aside>

    <!-- MAIN CONTENT -->
    <main class="proj-main">
      <div class="proj-content">

        <div class="breadcrumb">
          <a href="/">home</a><span>/</span>
          <a href="/projects">projects</a><span>/</span>
          <a href={introUrl} style="color: var(--blue);">{ip.title.toLowerCase()}</a>
          {p.chapter > 0 && (
            <><span>/</span><span style="color: var(--text-dim);">{p.title.toLowerCase()}</span></>
          )}
        </div>

        <div class="chapter-header">
          {p.chapter === 0 ? (
            <>
              <div class="page-header__meta">
                <span class="tag tag--project">project</span>
                <span class={'status status--' + ip.status}>
                  <span class="status__dot"></span>{ip.status}
                </span>
                <span class="dot"></span>
                <span class="mono-dim">{ip.date}</span>
                {ip.version && <span class="mono-dim">{'v' + ip.version}</span>}
              </div>
              <h1>{ip.title}</h1>
              <p class="chapter-desc">{ip.desc}</p>
              {ip.tags && (
                <div class="page-header__tags" style="margin-top: 1rem;">
                  {ip.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </>
          ) : (
            <>
              <div class="chapter-num">{'Chapter ' + p.chapter}</div>
              <h1>{p.title}</h1>
            </>
          )}
        </div>

        {ip.github && p.chapter === 0 && (
          <div style="margin-bottom: 2rem;">
            <a href={ip.github} class="related-link" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="opacity:0.6;flex-shrink:0;">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              View Source Code on GitHub
            </a>
          </div>
        )}

        <div class="prose">
          <Content />
        </div>

        {p.chapter === 0 && (
          <>
            {ip.concepts && ip.concepts.length > 0 && (
              <div class="related-section">
                <p class="section-label">Related Concepts</p>
                <div class="related-grid">
                  {ip.concepts.map((c: Link) => (
                    <a href={'/concepts/' + c.slug} class="related-link">
                      <span class="tag tag--concept" style="margin:0;padding:0.15em 0.4em;font-size:0.6rem;">concept</span>
                      {c.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
            {ip.resources && ip.resources.length > 0 && (
              <div class="related-section" style="margin-top:2rem;padding-top:0;border:none;">
                <p class="section-label">Related Resources</p>
                <div class="related-grid">
                  {ip.resources.map((r: Link) => (
                    <a href={'/resources/' + r.slug} class="related-link">
                      <span class="tag tag--resource" style="margin:0;padding:0.15em 0.4em;font-size:0.6rem;">resource</span>
                      {r.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
            {ip.experiments && ip.experiments.length > 0 && (
              <div class="related-section" style="margin-top:2rem;padding-top:0;border:none;">
                <p class="section-label">Related Experiments</p>
                <div class="related-grid">
                  {ip.experiments.map((e: Link) => (
                    <a href={'/experiments/' + e.slug} class="related-link">
                      <span class="tag tag--experiment" style="margin:0;padding:0.15em 0.4em;font-size:0.6rem;">exp</span>
                      {e.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </>
        )}

        <div class="chapter-nav">
          {prevChapter && (
            <a href={'/projects/' + projSlug + '/' + prevChapter.data.chapter} class="chapter-nav__btn chapter-nav__btn--prev">
              {'← ' + prevChapter.data.title}
            </a>
          )}
          {nextChapter && (
            <a href={'/projects/' + projSlug + '/' + nextChapter.data.chapter} class="chapter-nav__btn chapter-nav__btn--next">
              {nextChapter.data.title + ' →'}
            </a>
          )}
        </div>
      </div>
    </main>

    <!-- RIGHT TOC -->
    {headings.filter((h: Heading) => h.depth <= 3).length > 0 && (
      <aside class="proj-toc" id="proj-toc">
        <p class="proj-toc__label">On this page</p>
        <nav class="proj-toc__nav">
          {headings
            .filter((h: Heading) => h.depth <= 3)
            .map((h: Heading) => (
              <a
                href={'#' + h.slug}
                class={'proj-toc__link proj-toc__link--h' + h.depth}
                data-heading={h.slug}
              >
                {h.text}
              </a>
            ))
          }
        </nav>
      </aside>
    )}

  </div>
</Base>

<button class="proj-sidebar-toggle" id="sidebar-toggle" aria-label="Toggle chapters">
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
  Chapters
</button>

<script>
  document.getElementById('sidebar-toggle')?.addEventListener('click', () => {
    document.getElementById('proj-sidebar')?.classList.toggle('open');
  });
</script>

<style>
.proj-layout {
  display: grid;
  grid-template-columns: 240px 1fr 200px;
  min-height: calc(100vh - 60px);
  max-width: 1400px;
  margin: 0 auto;
}

/* ── Left sidebar ── */
.proj-sidebar {
  position: sticky;
  top: 60px;
  height: calc(100vh - 60px);
  overflow-y: auto;
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

.proj-sidebar__header {
  padding: 1.75rem 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.proj-sidebar__back {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  display: block;
  margin-bottom: 1rem;
  text-decoration: none;
}
.proj-sidebar__back:hover { color: var(--text); }

.proj-sidebar__title {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 0.6rem;
  line-height: 1.3;
}

.proj-sidebar__meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.proj-sidebar__version {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-muted);
  background: var(--bg-3);
  border: 1px solid var(--border);
  padding: 0.1em 0.45em;
  border-radius: 3px;
}

.proj-sidebar__nav {
  flex: 1;
  padding: 0.6rem 0;
  overflow-y: auto;
}

.proj-sidebar__link {
  display: flex;
  align-items: baseline;
  gap: 0.65rem;
  padding: 0.55rem 1.25rem;
  text-decoration: none;
  border-left: 2px solid transparent;
  transition: background 0.15s ease;
}

.proj-sidebar__link:hover {
  background: var(--bg-2);
}

.proj-sidebar__link.active {
  background: var(--bg-2);
  border-left-color: var(--blue);
}

.proj-sidebar__link-num {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-muted);
  min-width: 1.8rem;
  flex-shrink: 0;
}

.proj-sidebar__link-title {
  font-size: 0.82rem;
  color: var(--text-dim);
  line-height: 1.4;
}

.proj-sidebar__link.active .proj-sidebar__link-title { color: var(--text); }

.proj-sidebar__github {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 1rem 1.25rem 0;
  padding: 0.5rem 0.75rem;
  font-family: var(--font-mono);
  font-size: 0.63rem;
  color: var(--text-muted);
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-decoration: none;
  transition: var(--transition);
  flex-shrink: 0;
}
.proj-sidebar__github:hover { color: var(--text); border-color: var(--border-hover); }

.proj-sidebar__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  padding: 1rem 1.25rem;
  flex-shrink: 0;
}

.proj-sidebar__changelog {
  margin: 0 1.25rem 1.5rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}

.changelog-entry { margin-bottom: 1rem; }

.changelog-version {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  color: var(--blue);
  background: rgba(122,156,200,0.08);
  border: 1px solid rgba(122,156,200,0.2);
  padding: 0.1em 0.4em;
  border-radius: 3px;
  margin-right: 0.35rem;
}

.changelog-date {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-muted);
}

.changelog-notes {
  font-size: 0.78rem;
  color: var(--text-muted);
  margin-top: 0.2rem;
  line-height: 1.5;
}

/* ── Main content ── */
.proj-main {
  min-width: 0;
  padding: 3rem 3.5rem 6rem;
}

.proj-content { max-width: 68ch; }

.breadcrumb {
  font-family: var(--font-mono);
  font-size: 0.67rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.4rem;
  align-items: center;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}
.breadcrumb a { color: var(--text-muted); text-decoration: none; }
.breadcrumb a:hover { color: var(--text); }

.chapter-header { margin-bottom: 2.5rem; }

.chapter-num {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.6rem;
}

.chapter-header h1 { margin-bottom: 0.75rem; }

.chapter-desc {
  font-size: 0.97rem;
  color: var(--text-dim);
  max-width: 52ch;
  line-height: 1.8;
  margin-top: 0.75rem;
}

.mono-dim { font-family: var(--font-mono); font-size: 0.67rem; color: var(--text-muted); }

.chapter-nav {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}

.chapter-nav__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-muted);
  text-decoration: none;
  padding: 0.5rem 0.9rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: var(--transition);
  max-width: 46%;
  line-height: 1.4;
}

.chapter-nav__btn:hover {
  color: var(--text);
  border-color: var(--border-hover);
  background: var(--bg-2);
}

.chapter-nav__btn--next { margin-left: auto; text-align: right; }

/* ── Right ToC ── */
.proj-toc {
  position: sticky;
  top: 80px;
  height: fit-content;
  padding: 3rem 1.25rem 2rem 1rem;
}

.proj-toc__label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.85rem;
}

.proj-toc__nav {
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
}

.proj-toc__link {
  font-size: 0.74rem;
  color: var(--text-muted);
  text-decoration: none;
  line-height: 1.4;
  padding: 0.25rem 0.5rem;
  border-left: 1px solid var(--border);
  transition: color 0.15s ease, border-color 0.15s ease;
  display: block;
}

.proj-toc__link:hover { color: var(--text-secondary); border-left-color: var(--border-hover); }
.proj-toc__link.active { color: var(--text); border-left-color: var(--blue); }
.proj-toc__link--h3 { padding-left: 1.1rem; font-size: 0.7rem; }

/* ── Mobile toggle ── */
.proj-sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 5rem;
  left: 1rem;
  z-index: 80;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 0.5rem 0.8rem;
  color: var(--text-muted);
  cursor: pointer;
}

@media (max-width: 1100px) {
  .proj-layout { grid-template-columns: 220px 1fr; }
  .proj-toc { display: none; }
}

@media (max-width: 750px) {
  .proj-layout { grid-template-columns: 1fr; }
  .proj-sidebar {
    position: fixed;
    top: 60px; left: 0; bottom: 0;
    width: 260px;
    background: var(--bg-1);
    z-index: 70;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    border-right: 1px solid var(--border);
  }
  .proj-sidebar.open { transform: translateX(0); }
  .proj-main { padding: 2rem 1.25rem 5rem; }
  .proj-sidebar-toggle { display: flex; }
}
</style>
