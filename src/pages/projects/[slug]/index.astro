---
// /projects/[slug]/index.astro  — redirects to the intro chapter
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('projects');
  // Get unique project slugs (folder names)
  const slugs = [...new Set(all.map(e => e.id.split('/')[0]))];
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
return Astro.redirect(`/projects/${slug}/0`, 301);
---
